{
  "name": "@affordance-atlas/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "dev": "pnpm --filter @affordance-atlas/domain build && wrangler dev",
    "deploy:worker": "pnpm --filter @affordance-atlas/domain build && wrangler deploy",
    "typecheck": "pnpm --filter @affordance-atlas/domain build && tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @affordance-atlas/domain build && vitest run"
  },
  "dependencies": {
    "@affordance-atlas/domain": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.16.2",
    "ai": "^6.0.207",
    "workers-ai-provider": "^3.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260613.1",
    "typescript": "^5.9.0",
    "vitest": "^3.1.3",
    "wrangler": "^4.0.0"
  }
}
