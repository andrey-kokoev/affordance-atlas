{
  "name": "@affordance-atlas/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @affordance-atlas/domain build && vite",
    "build": "pnpm --filter @affordance-atlas/domain build && vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "pnpm --filter @affordance-atlas/domain build && vue-tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:mcp": "node e2e-node/mcp.mjs",
    "audit:visual": "node scripts/visual-snapshot-audit.mjs",
    "audit:visual:manual": "node scripts/visual-snapshot-audit.mjs --require-manual-review",
    "audit:visual:manual:selftest": "node scripts/visual-snapshot-manual-gate-selftest.mjs"
  },
  "dependencies": {
    "@affordance-atlas/domain": "workspace:*",
    "agents": "^0.16.2",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-vue": "^6.0.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.0",
    "vite": "^8.0.0",
    "vue-tsc": "^3.0.0"
  }
}
